# ──────────────────────────────────────────────────────────────
#  Mini Data Platform — Example Environment Configuration
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_ADMIN_USER=
POSTGRES_ADMIN_PASSWORD=

AIRFLOW_DB=airflow
AIRFLOW_DB_USER=
AIRFLOW_DB_PASSWORD=

SALES_DB=salesdb
SALES_DB_USER=
SALES_DB_PASSWORD=

METABASE_DB=metabase

# ── MinIO ──────────────────────────────────────────────────────
MINIO_HOST=minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_SOURCE_BUCKET=sales-data
MINIO_ARCHIVE_BUCKET=processed-data

# ── Airflow ────────────────────────────────────────────────────
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_ADMIN_USER=
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=

# ── Metabase ───────────────────────────────────────────────────
METABASE_PORT=3000
