# ──────────────────────────────────────────────────────────────
#  Mini Data Platform — Environment Configuration
#  Copy this file to .env and adjust values as needed.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_ADMIN_USER=admin
POSTGRES_ADMIN_PASSWORD=adminpass

# Airflow metadata DB
AIRFLOW_DB=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow

# Sales data DB
SALES_DB=salesdb
SALES_DB_USER=datauser
SALES_DB_PASSWORD=datapass

# Metabase metadata DB (uses admin credentials)
METABASE_DB=metabase

# ── MinIO ──────────────────────────────────────────────────────
MINIO_HOST=minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_SOURCE_BUCKET=sales-data
MINIO_ARCHIVE_BUCKET=processed-data

# ── Airflow ────────────────────────────────────────────────────
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
